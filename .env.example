OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

OKX_DEMO_API_KEY=
OKX_DEMO_API_SECRET=
OKX_DEMO_PASSPHRASE=

# Funding / Asset live integration tests.
# Keep this disabled unless you intentionally want tests to call real asset
# mutation endpoints such as transfer, withdrawal, dust conversion, or
# Lightning withdrawal.
OKX_ENABLE_ASSET_MUTATION=0

# Read-only Funding examples/tests.
OKX_TEST_DEPOSIT_CCY=USDT
OKX_EXAMPLE_FUNDING_CCY=USDT

# Optional transfer-state lookup.
OKX_TEST_TRANSFER_ID=
OKX_TEST_TRANSFER_TYPE=

# Optional deposit/withdraw status lookup.
OKX_TEST_STATUS_WD_ID=
OKX_TEST_STATUS_TX_ID=
OKX_TEST_STATUS_CCY=
OKX_TEST_STATUS_TO=
OKX_TEST_STATUS_CHAIN=

# Real funds transfer test. Requires OKX_ENABLE_ASSET_MUTATION=1.
OKX_TEST_TRANSFER_CCY=
OKX_TEST_TRANSFER_AMT=
OKX_TEST_TRANSFER_FROM=
OKX_TEST_TRANSFER_TO=

# Real withdrawal test. Requires OKX_ENABLE_ASSET_MUTATION=1.
OKX_TEST_WITHDRAWAL_CCY=
OKX_TEST_WITHDRAWAL_AMT=
OKX_TEST_WITHDRAWAL_DEST=
OKX_TEST_WITHDRAWAL_TO_ADDR=
OKX_TEST_WITHDRAWAL_CHAIN=
OKX_TEST_WITHDRAWAL_AREA_CODE=
OKX_TEST_WITHDRAWAL_CLIENT_ID=
OKX_TEST_WITHDRAWAL_TO_ADDR_TYPE=
OKX_TEST_CANCEL_WITHDRAWAL_ID=

# Real savings/dust/Lightning tests. Requires OKX_ENABLE_ASSET_MUTATION=1.
OKX_TEST_PURCHASE_REDEMPT_CCY=
OKX_TEST_PURCHASE_REDEMPT_AMT=
OKX_TEST_PURCHASE_REDEMPT_SIDE=
OKX_TEST_PURCHASE_REDEMPT_RATE=
OKX_TEST_DUST_CCY=
OKX_TEST_LIGHTNING_CCY=
OKX_TEST_LIGHTNING_AMT=
OKX_TEST_LIGHTNING_INVOICE=
OKX_TEST_LIGHTNING_MEMO=

# Live trading example. Requires OKX_LIVE_TRADING_CONFIRM=I_UNDERSTAND.
OKX_LIVE_TRADING_CONFIRM=
OKX_TRADE_INST_ID=BTC-USDT
OKX_TRADE_SIDE=buy
OKX_TRADE_SIZE=
