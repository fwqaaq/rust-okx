# Funding / Asset live integration tests.
# Keep this disabled unless you intentionally want tests to call real asset
# mutation endpoints such as transfer, withdrawal, dust conversion, or
# Lightning withdrawal.
OKX_ENABLE_ASSET_MUTATION=0

# Read-only Funding examples/tests.
OKX_TEST_DEPOSIT_CCY=USDT
OKX_EXAMPLE_FUNDING_CCY=USDT

# Optional transfer-state lookup.
OKX_TEST_TRANSFER_ID=
OKX_TEST_TRANSFER_TYPE=

# Optional deposit/withdraw status lookup.
