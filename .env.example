OKX_TEST_STATUS_TX_ID=
OKX_TEST_STATUS_CCY=
OKX_TEST_STATUS_TO=
OKX_TEST_STATUS_CHAIN=

# Real funds transfer test. Requires OKX_ENABLE_ASSET_MUTATION=1.
